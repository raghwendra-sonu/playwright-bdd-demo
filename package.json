{
  "name": "playwright-bdd-automation-demo",
  "version": "1.0.0",
  "description": "Playwright BDD UI and API Automation Framework",
  "author": "Raghwendra Sonu",
  "license": "ISC",
  "scripts": {
    "bddgen": "npx bddgen",
    "test": "npx playwright test",
    "test:chrome": "npx playwright test --project=Chrome",
    "test:edge": "npx playwright test --project=Edge",
    "test:api": "npx playwright test --project=API",
    "report": "allure generate allure-results --clean -o allure-report",
    "report:open": "allure open allure-report",
    "format": "prettier --write \"**/*.{ts,js,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,json,md}\""
  },
  "dependencies": {
    "playwright": "1.55.0"
  },
  "devDependencies": {
    "@playwright/test": "1.55.0",
    "@types/node": "^20.14.11",
    "allure-commandline": "^2.34.1",
    "allure-playwright": "^3.3.3",
    "playwright-bdd": "8.4.0",
    "prettier": "^3.6.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.2",
    "dotenv": "17.2.1"
  },
  "overrides": {
    "@playwright/test": "1.55.0",
    "playwright": "1.55.0",
    "playwright-bdd": "8.4.0"
  }
}

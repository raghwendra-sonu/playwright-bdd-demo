{
  "compilerOptions": {
    "sourceMap": true,
    "inlineSources": true,
    "target": "ESNext",
    "module": "CommonJS",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "dist"
  },
  "include": ["tests/**/features/*.ts", "tests/**/steps/*.ts", "playwright.config.ts"]
}
